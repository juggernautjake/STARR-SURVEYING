{
  "expo": {
    "name": "Starr Field",
    "slug": "starr-field",
    "scheme": "starr-field",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starrsoftware.starrfield",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Starr Field uses Face ID to unlock the app and confirm sensitive actions like deleting field data."
      }
    },
    "android": {
      "package": "com.starrsoftware.starrfield",
      "adaptiveIcon": {
        "backgroundColor": "#1D3095"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Starr Field uses Face ID to unlock the app and confirm sensitive actions like deleting field data."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
