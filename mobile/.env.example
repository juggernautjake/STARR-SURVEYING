# Starr Field — mobile env template
# Copy to .env.local for local dev; set the same values in your EAS
# build profile (eas.json) for staging / production builds.
#
# These values are embedded in the JS bundle. Only put PUBLIC values
# here — service-role keys and Anthropic API keys live on the server,
# never on the device.

# Public Supabase project URL (same project as the web app)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Public Supabase anon key — safe to embed (JWT, scoped to anon role)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# PowerSync service URL (e.g. https://xxxx.powersync.journeyapps.com).
# OPTIONAL — when missing or empty, the local SQLite database still
# works fully offline; only the cloud sync layer is disabled. See
# mobile/lib/db/README.md for the deployment runbook.
EXPO_PUBLIC_POWERSYNC_URL=

# Sentry DSN (e.g. https://[hash]@o[org].ingest.sentry.io/[project]).
# OPTIONAL — when missing or empty, lib/sentry.ts skips Sentry.init
# and the app runs without crash reporting. Sentry DSNs are designed
# to be embedded in clients, so this is safe in EXPO_PUBLIC_*.
EXPO_PUBLIC_SENTRY_DSN=
