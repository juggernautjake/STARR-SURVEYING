# Starr Field — mobile env template
# Copy to .env.local for local dev; set the same values in your EAS
# build profile (eas.json) for staging / production builds.
#
# These values are embedded in the JS bundle. Only put PUBLIC values
# here — service-role keys and Anthropic API keys live on the server,
# never on the device.

# Public Supabase project URL (same project as the web app)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Public Supabase anon key — safe to embed (JWT, scoped to anon role)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
