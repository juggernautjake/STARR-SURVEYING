{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/continue-until-planning-done.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(supabase --version)",
      "Bash(supabase --help)",
      "Bash(supabase db --help)",
      "Bash(supabase db query --help)",
      "Bash(supabase projects list)",
      "Bash(supabase projects list *)",
      "Bash(supabase status)",
      "Bash(supabase status *)",
      "Bash(supabase orgs list)",
      "Bash(supabase functions list *)",
      "Bash(supabase secrets list *)",
      "Bash(vercel --version)",
      "Bash(vercel whoami)",
      "Bash(vercel ls)",
      "Bash(vercel ls *)",
      "Bash(vercel projects ls)",
      "Bash(vercel env ls)",
      "Bash(vercel env ls *)",
      "Bash(vercel domains ls)",
      "Bash(vercel inspect *)",
      "Bash(npm run type-check)",
      "Bash(npm run lint)",
      "Bash(npm ls *)",
      "Bash(npm outdated)",
      "Bash(npm outdated *)",
      "Bash(npm view *)",
      "Bash(npm config get *)"
    ]
  }
}
