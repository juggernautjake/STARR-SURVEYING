# Starr Research Worker — Environment Variables
# Copy this to .env on the DigitalOcean droplet at /root/starr-worker/.env

# Bearer token for authenticating requests to this worker
WORKER_API_KEY=your-secret-worker-api-key

# Anthropic API key for Claude AI extraction + Vision OCR
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Supabase project connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Runtime config
NODE_ENV=production
PLAYWRIGHT_HEADLESS=true
PORT=3100
