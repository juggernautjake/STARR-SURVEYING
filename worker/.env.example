# Starr Research Worker — Environment Variables
# Copy this to .env on the deployment host (Hetzner in Phase A; DigitalOcean
# droplet during the migration overlap).

# ── Authentication ──────────────────────────────────────────────────────────
# Bearer token clients use to call this worker.
WORKER_API_KEY=your-secret-worker-api-key

# Anthropic API key for Claude AI extraction + Vision OCR.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Claude model pin (optional). Defaults to claude-sonnet-4-5-20250929.
# RESEARCH_AI_MODEL=claude-sonnet-4-5-20250929

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3100

# ── Browser backend ─────────────────────────────────────────────────────────
# Selects how worker/src/lib/browser-factory.ts acquires Chromium.
#   local        Run Playwright locally (development; default outside CI)
#   browserbase  Connect to a Browserbase CDP session (Phase A; needs keys)
#   stub         Return a fake browser whose methods throw (CI / unit tests)
BROWSER_BACKEND=local
PLAYWRIGHT_HEADLESS=true

# Browserbase credentials (Phase A — leave blank in stub mode).
# Sign up at https://www.browserbase.com → Project → API Keys.
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
#
# Per-adapter routing for the browserbase backend. Comma-separated list
# of adapter ids (filename stems, e.g. "bell-clerk,fidlar-clerk"). When
# empty, NO adapter is routed to Browserbase even if BROWSER_BACKEND=browserbase.
# Unknown ids in the list are warned-and-ignored at startup.
# BROWSERBASE_ENABLED_ADAPTERS=

# ── CAPTCHA solver ──────────────────────────────────────────────────────────
# Selects worker/src/lib/captcha-solver.ts provider.
#   stub       Deterministic fake solver for development + CI (default)
#   capsolver  Real CapSolver provider (Phase A — needs CAPSOLVER_API_KEY)
CAPTCHA_PROVIDER=stub

# Stub solver mode — controls how the stub responds, useful for testing
# escalation paths. Ignored when CAPTCHA_PROVIDER=capsolver.
#   success  Return a fake token (default)
#   fail     Throw provider_error
#   manual   Throw manual_handoff_required
#   timeout  Throw timeout
# CAPTCHA_STUB_MODE=success

# CapSolver credentials (Phase A — leave blank in stub mode).
# Sign up at https://capsolver.com → Dashboard → API Key.
# CAPSOLVER_API_KEY=

# ── Object storage (Cloudflare R2) ──────────────────────────────────────────
# Provider-agnostic abstraction in worker/src/lib/storage.ts. New code
# (Phase A integrations) writes through this layer; existing
# artifact-uploader.ts call sites remain on Supabase Storage until a
# future migration PR (see docs/planning/in-progress/PHASE_A_INTEGRATION_PREP.md).
#   local  Write to ./storage/ on the worker disk (default; dev + CI)
#   r2     Write to Cloudflare R2 via the S3 API
STORAGE_BACKEND=local
# STORAGE_LOCAL_ROOT=./storage

# R2 credentials (only consumed when STORAGE_BACKEND=r2).
# Endpoint is https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=starr-recon-artifacts
# Note: legacy R2_BUCKET_DOCUMENTS / R2_BUCKET_REPORTS / R2_PUBLIC_BASE
# from earlier sketches were removed — storage.ts only consumes R2_BUCKET.
# When artifact-uploader.ts is migrated to storage.ts (separate future PR),
# any additional bucket vars are introduced there.

# ── Redis (BullMQ + WebSocket pub/sub) ──────────────────────────────────────
# Used by BullMQ for job queueing and by the WebSocket server (server/ws.ts)
# for fanning research-progress events from the worker out to clients.
# REDIS_URL=redis://localhost:6379

# ── WebSocket research-progress channel ─────────────────────────────────────
# Worker emits research events (job started, document discovered, captcha
# resolved, etc.) into Redis; server/ws.ts subscribes and fans them out
# to authorized browser clients. See docs/platform/WEBSOCKET_ARCHITECTURE.md.
# WS_TICKET_SECRET is the HMAC secret for short-lived (60s) connection
# tickets. Deliberately distinct from NEXTAUTH_SECRET so WS auth can be
# rotated independently. Generate with: openssl rand -hex 32
# WS_TICKET_SECRET=

# ── Closure tolerance overrides (optional, per-deploy) ──────────────────────
# Override the defaults in worker/src/lib/closure-tolerance.ts. Counties
# may further override per-county via county-config-registry. See
# docs/CLOSURE_TOLERANCE.md.
# CLOSURE_EXCELLENT_RATIO=10000
# CLOSURE_ACCEPTABLE_RATIO=5000
# CLOSURE_MARGINAL_RATIO=2500
