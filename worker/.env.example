# Starr Research Worker — Environment Variables
# Copy this to .env on the DigitalOcean droplet at /root/starr-worker/.env

# Bearer token for authenticating requests to this worker
WORKER_API_KEY=your-secret-worker-api-key

# Anthropic API key for Claude AI extraction + Vision OCR
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Supabase project connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Runtime config
NODE_ENV=production
PLAYWRIGHT_HEADLESS=true
PORT=3100

# Claude model to use for all AI extraction (optional — defaults to claude-sonnet-4-5-20250929)
# Override here to pin a specific version or switch to a newer model.
# RESEARCH_AI_MODEL=claude-sonnet-4-5-20250929
