{
  "name": "starr-worker",
  "version": "5.0.0",
  "description": "Starr Research Pipeline — AI property research worker for DigitalOcean droplet",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
