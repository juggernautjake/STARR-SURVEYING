    "@browserbasehq/sdk": "2.10.0",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.38.5",
    "bullmq": "^5.70.4",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "ioredis": "^5.10.0",
    "pdfkit": "^0.17.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.10.0",
