# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Supabase Service Role Key (KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Mailgun Configuration  
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.starr-surveying.com

# Business Email Configuration
BUSINESS_EMAIL=info@starr-surveying.com
ADMIN_EMAIL=hankmaddux@starr-surveying.com

# Anthropic API Key (for AI-powered essay grading + property research analysis)
ANTHROPIC_API_KEY=sk-ant-api...

# AI Property Research (Phase 2+)
RESEARCH_AI_MODEL=claude-sonnet-4-5-20250929
RESEARCH_MAX_FILE_SIZE_MB=50
RESEARCH_MAX_PROJECT_STORAGE_MB=500

# Property Search APIs (Phase 3 — optional, enables county record discovery)
# TNRIS_API_KEY=...
# FEMA_API_KEY=...

# File Storage — uses Supabase Storage by default (no extra config needed)
# For S3 storage, uncomment and configure:
# RESEARCH_S3_BUCKET=starr-research-documents
# RESEARCH_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Optional: Node Environment
NODE_ENV=development

# Browser Automation (Active Property Research)
# On Vercel, @sparticuz/chromium is used automatically — no extra steps needed.
# On a self-hosted server, run: npx playwright install chromium --with-deps
# Set this to prevent Playwright from downloading its own browser on build servers
# where @sparticuz/chromium is handling the binary instead:
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Deep Research Worker (DigitalOcean Droplet)
# The worker handles Playwright-based county CAD/clerk scraping, multi-page document
# capture, and AI extraction. It runs as a separate Express server on port 3100.
WORKER_URL=http://104.131.20.240:3100
WORKER_API_KEY=your-secret-worker-api-key