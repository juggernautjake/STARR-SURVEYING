# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Supabase Service Role Key (KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Mailgun Configuration  
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.starr-surveying.com

# Business Email Configuration
BUSINESS_EMAIL=info@starr-surveying.com
ADMIN_EMAIL=hankmaddux@starr-surveying.com

# Anthropic API Key (for AI-powered essay grading + property research analysis)
ANTHROPIC_API_KEY=sk-ant-api...

# AI Property Research (Phase 2+)
RESEARCH_AI_MODEL=claude-sonnet-4-6
RESEARCH_MAX_FILE_SIZE_MB=50
RESEARCH_MAX_PROJECT_STORAGE_MB=500

# Property Search APIs (Phase 3 — optional, enables county record discovery)
# TNRIS_API_KEY=...
# FEMA_API_KEY=...

# File Storage — uses Supabase Storage by default (no extra config needed)
# For S3 storage, uncomment and configure:
# RESEARCH_S3_BUCKET=starr-research-documents
# RESEARCH_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Optional: Node Environment
NODE_ENV=development

# Browser Automation (Active Property Research)
# On Vercel, @sparticuz/chromium is used automatically — no extra steps needed.
# On a self-hosted server, run: npx playwright install chromium --with-deps
# Set this to prevent Playwright from downloading its own browser on build servers
# where @sparticuz/chromium is handling the binary instead:
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

# Deep Research Worker (DigitalOcean Droplet)
# The worker handles Playwright-based county CAD/clerk scraping, multi-page document
# capture, and AI extraction. It runs as a separate Express server on port 3100.
WORKER_URL=http://104.131.20.240:3100
WORKER_API_KEY=your-secret-worker-api-key

# Stripe Billing — Phase 11 Subscription Platform
# Get price IDs from your Stripe Dashboard → Products
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SURVEYOR_PRO=price_...
STRIPE_PRICE_FIRM_UNLIMITED=price_...

# Phase 11 Batch & Queue (Redis required for BullMQ)
REDIS_URL=redis://localhost:6379
# ───────────────────────────────────────────────────────────────────────────
# Phase A integration prep — defaults keep behavior unchanged in current deploy.
# Activation flips happen one feature at a time when external accounts are
# provisioned. See docs/planning/in-progress/PHASE_A_INTEGRATION_PREP.md.
# ───────────────────────────────────────────────────────────────────────────

# Browserbase (worker-only — set in worker/.env, not here):
#   BROWSER_BACKEND=local|browserbase, BROWSERBASE_API_KEY,
#   BROWSERBASE_PROJECT_ID, BROWSERBASE_ENABLED_ADAPTERS

# CapSolver (worker-only — set in worker/.env, not here):
#   CAPTCHA_PROVIDER=stub|capsolver, CAPSOLVER_API_KEY

# Cloudflare R2 storage (worker-only — set in worker/.env, not here):
#   STORAGE_BACKEND=local|r2, R2_ACCOUNT_ID, R2_ACCESS_KEY_ID,
#   R2_SECRET_ACCESS_KEY, R2_BUCKET

# WebSocket real-time progress channel (Next.js + standalone WS server):
# Generate with: openssl rand -hex 32
# Distinct from NEXTAUTH_SECRET so WS auth can be rotated independently.
WS_TICKET_SECRET=
# Port for the standalone server/ws.ts process (npm run ws). Defaults 3001.
WEBSOCKET_PORT=3001
# Browser-side override for the WS endpoint. Defaults to wss://<host>:3001
# in production, ws://localhost:3001 in dev. Set this when terminating
# WSS at a different hostname or path.
# NEXT_PUBLIC_WS_URL=
